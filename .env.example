# 복사해서 .env 로 저장하고 실제 키 입력 (절대 커밋 금지)
# 공공데이터포털(data.go.kr) 마이페이지 > 활용신청 목록에서 발급 (일반 인증키 Decoding 값 사용)
TOURAPI_KEY=            # 15101578 국문 관광정보 서비스
KTO_CONGESTION_KEY=     # 15128555 관광지 집중률 방문자 추이 예측
KTO_VISITOR_KEY=        # 15101972 빅데이터 지역별 방문자수
KTO_RELATED_KEY=        # 15128560 관광지별 연관 관광지 (보너스)
KMA_KEY=                # 15084084 기상청 단기예보
SEOUL_KEY=              # data.seoul.go.kr 인증키 (citydata)
